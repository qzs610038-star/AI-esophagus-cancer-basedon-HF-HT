# ============================================
# PFMval 项目 Git 忽略规则
# 排除训练数据、模型权重、缓存及环境文件
# ============================================

# --------------------------------------------
# 1. 训练数据（体积大，不上传）
# --------------------------------------------
# 3ST 数据集：原始 patch 图片和标签 CSV
data_new_3ST/

# HYZ15040 原始 patch 图片目录（超过 1 万张图片）
HYZ15040_old/

# OpenMidnight 原始数据目录
openmidnight/data/

# 病理图像原始格式
*.tiff
*.tif

# 原始压缩包（HYZ15040 原始数据，约 950MB）
HYZ15040-org.zip

# --------------------------------------------
# 2. 模型权重与检查点（体积大，可重新训练生成）
# --------------------------------------------
# 所有 .pth 权重文件（包含 checkpoints 目录下及根目录下的）
**/*.pth

# 根目录 checkpoints 目录（完全忽略，仅匹配根目录）
/checkpoints/

# 注意：子目录（如 histogene/checkpoints/）不整体忽略，
# 因为其中可能包含 results_vis 可视化结果子目录。
# 子目录中的 .pth 权重文件已由 **/*.pth 规则覆盖。

# --------------------------------------------
# 3. 特征提取缓存（可重新生成）
# --------------------------------------------
# UNI2-h 特征缓存
uni2h_cache/
**/uni2h_cache/

# UNI Token 特征缓存（体积巨大，34GB+，不可提交）
uni2h_cache_tokens/
uni2h_cache_tokens_aug/
**/uni2h_cache_tokens/
**/uni2h_cache_tokens_aug/

# ViT / ResNet 等中间特征缓存（egnv1/cache/, egnv2/cache/ 等）
**/cache/

# --------------------------------------------
# 4. Python 运行时缓存
# --------------------------------------------
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# --------------------------------------------
# 5. 虚拟环境与依赖安装包
# --------------------------------------------
# Python 虚拟环境
.venv/
venv/
env/
ENV/

# 环境变量文件
.env

# Conda 相关
.conda/

# 构建产物
dist/
build/
*.egg-info/
.eggs/

# --------------------------------------------
# 6. 训练产物（大文件排除，小文件保留）
# --------------------------------------------
# 大型预测结果 CSV（每个可达数百 MB）
**/results_vis/**/predictions.csv

# 暂停训练信号文件
PAUSE_TRAINING

# 日志文件
*.log

# 大型提取日志（2MB+）
extract_aug_log.txt

# --------------------------------------------
# 7. IDE 与编辑器配置
# --------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --------------------------------------------
# 8. 系统文件
# --------------------------------------------
Thumbs.db
.DS_Store
desktop.ini

# --------------------------------------------
# 9. 其他临时文件
# --------------------------------------------
*.tmp
*.bak

# 训练状态监控临时文件
training_status_*.txt

# 临时调试脚本（temp_*.py）
temp_*.py
