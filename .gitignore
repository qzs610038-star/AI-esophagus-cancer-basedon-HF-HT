# ============================================
# PFMval 项目 Git 忽略规则
# 排除训练数据、模型权重、缓存及环境文件
# ============================================

# --------------------------------------------
# 1. 训练数据（体积大，不上传）
# --------------------------------------------
# 3ST 数据集：原始 patch 图片和标签 CSV
data_new_3ST/

# HYZ15040 原始 patch 图片目录（超过 1 万张图片）
HYZ15040_old/

# OpenMidnight 原始数据目录
openmidnight/data/

# 病理图像原始格式
*.tiff
*.tif

# 部署密钥（包含服务器密码，绝对不能提交）
deploy/secrets.sh

# 原始压缩包（HYZ15040 原始数据，约 950MB）
HYZ15040-org.zip

# 所有压缩包和归档文件
*.zip
*.tar.gz
*.tar
*.rar
*.7z

# 部署打包文件
pfmval_deploy_*.tar.gz

# --------------------------------------------
# 2. 模型权重与检查点（体积大，可重新训练生成）
# --------------------------------------------
# 所有 .pth 权重文件（包含 checkpoints 目录下及根目录下的）
**/*.pth

# 根目录 checkpoints 目录（完全忽略，仅匹配根目录）
/checkpoints/

# uni2h_new 子目录下的 checkpoints（模型权重 + 训练产物）
uni2h_new/checkpoints/

# 注意：子目录（如 histogene/checkpoints/）不整体忽略，
# 因为其中可能包含 results_vis 可视化结果子目录。
# 子目录中的 .pth 权重文件已由 **/*.pth 规则覆盖。

# --------------------------------------------
# 3. 特征提取缓存（可重新生成）
# --------------------------------------------
# UNI2-h 特征缓存
uni2h_cache/
**/uni2h_cache/

# UNI2-h 特征缓存（uni2h_new 子目录下）
uni2h_new/uni2h_cache/
uni2h_new/uni2h_cache_30/

# UNI Token 特征缓存（体积巨大，34GB+，不可提交）
uni2h_cache_tokens/
uni2h_cache_tokens_aug/
**/uni2h_cache_tokens/
**/uni2h_cache_tokens_aug/

# ViT / ResNet 等中间特征缓存（egnv1/cache/, egnv2/cache/ 等）
**/cache/

# --------------------------------------------
# 4. Python 运行时缓存
# --------------------------------------------
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# --------------------------------------------
# 5. 虚拟环境与依赖安装包
# --------------------------------------------
# Python 虚拟环境
.venv/
venv/
env/
ENV/

# 环境变量文件
.env

# Conda 相关
.conda/

# 构建产物
dist/
build/
*.egg-info/
.eggs/

# --------------------------------------------
# 6. 训练产物（大文件排除，小文件保留）
# --------------------------------------------
# 大型预测结果 CSV（每个可达数百 MB）
**/results_vis/**/predictions.csv

# 暂停训练信号文件
PAUSE_TRAINING

# 日志文件
*.log

# 大型提取日志（2MB+）
extract_aug_log.txt

# --------------------------------------------
# 7. IDE 与编辑器配置
# --------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --------------------------------------------
# 8. 系统文件
# --------------------------------------------
Thumbs.db
.DS_Store
desktop.ini

# --------------------------------------------
# 9. 其他临时文件
# --------------------------------------------
*.tmp
*.bak

# 训练状态监控临时文件
training_status_*.txt

# 临时调试脚本（temp_*.py）
temp_*.py

# --------------------------------------------
# 10. 新增 Backbone 特征缓存与权重（2026-05-20）
# --------------------------------------------
# HuggingFace 模型下载缓存
hf_cache/

# OmiCLIP 特征缓存
omiclip_cache/

# OmiCLIP 预训练权重（~7.14GB）
pretrained_omiclip/

# Virchow2 特征缓存
virchow2_cache_tokens/

# 第三方模型源码与仓库（只读参考，不直接维护）
loki_src/
virchow2/
virchow2_repo/

# --------------------------------------------
# 11. 文献与文档（体积大，不应版本控制）
# --------------------------------------------
# 旧数据目录（已被 data_new_3ST 替代）
data/

# PDF 文献（体积大，10-30MB/个，72个共~300MB）
*.pdf

# Office 文档
*.pptx
*.docx
*.doc

# 一次性检查/调试脚本
inspect_omiclip.py
inspect_omiclip2.py
run_omiclip_training.ps1
scripts/download_omiclip.py
